/f /fill load def
/w 200 def        %% image number of pixels wide
/h 200 def        %% image number of pixels high
/nh { h neg } def  %% negative of pixel height
/F { findfont ptsize scalefont setfont } def
/stringbox { stringwidth pop ptsize 0.7 mul } def
/CS {
   moveto dup stringbox
   2 div neg exch 2 div neg exch
   rmoveto show
} def
/RS {
   moveto
   dup stringwidth neg exch neg exch
   rmoveto show
} def
/LS {
   moveto show
} def
/FBOX {
   gsave
      moveto
      dup 0 exch rlineto
      exch 0 rlineto
      0 exch neg rlineto
      1 setgray fill
   grestore
} def
/ERASEBOX {
   gsave dup stringbox dup 0 exch rlineto
      exch dup 0 rlineto exch neg 0 exch rlineto
      neg 0 rlineto 1 setgray fill
   grestore
} def
/BS {
   moveto dup stringwidth
   exch dup 3 -1 roll
   2 div neg exch 2 div neg exch
   rmoveto ptsize 1.08 mul currentpoint FBOX 0 ptsize 0.08 mul rmoveto show
} def
/B { %% Draw box
  gsave
    moveto lineto lineto lineto
    closepath setlinewidth stroke
  grestore
} def
